{
  "name": "foundry",
  "version": "1.0.11",
  "description": "Foundry — The modern forge for building software",
  "main": "src/main/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -n vite,electron -c blue,green \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --publish never",
    "preview": "vite preview",
    "release:hash": "node scripts/generate-release-hash.js",
    "release": "npm run dist && npm run release:hash"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JJMcGil1/Foundry.git"
  },
  "keywords": [
    "ide",
    "editor",
    "foundry",
    "developer-tools"
  ],
  "author": "Foundry Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JJMcGil1/Foundry/issues"
  },
  "homepage": "https://github.com/JJMcGil1/Foundry#readme",
  "build": {
    "appId": "com.foundry.ide",
    "productName": "Foundry",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Development"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/renderer/assets/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "framer-motion": "^12.36.0",
    "ignore": "^7.0.5",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react-icons": "^5.6.0",
    "sql.js": "^1.14.1",
    "vscode-icons-js": "^11.6.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "png2icons": "^2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
